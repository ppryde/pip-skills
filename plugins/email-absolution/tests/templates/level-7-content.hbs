<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="en">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="x-apple-disable-message-reformatting">
  <title>HUGE SUMMER SALE - DON'T MISS OUT!!!</title>
  <style type="text/css">
    body { margin: 0; padding: 0; background-color: #f4f4f4; }
    table { border-collapse: separate; }
    img { border: 0; display: block; }
  </style>
</head>
<body style="margin: 0; padding: 0; background-color: #f4f4f4;">

  <!-- Preheader duplicates the h1 heading exactly — inbox preview line
       and the email opening will read identically, wasting both slots -->
  <div style="display: none; visibility: hidden; opacity: 0; mso-hide: all;
              font-size: 0; line-height: 0; max-height: 0; overflow: hidden;">
    HUGE SUMMER SALE - DON'T MISS OUT!!! Save up to 50% on everything.&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;
  </div>

  <table width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation"
         style="mso-table-lspace: 0pt; mso-table-rspace: 0pt; background-color: #f4f4f4;">
    <tr>
      <td align="center" style="padding-top: 32px; padding-bottom: 32px; padding-left: 16px; padding-right: 16px;">

        <!--[if mso]>
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="600">
          <tr><td>
        <![endif]-->
        <table width="600" border="0" cellpadding="0" cellspacing="0" role="presentation"
               style="mso-table-lspace: 0pt; mso-table-rspace: 0pt; background-color: #ffffff;">

          <!-- Header -->
          <tr>
            <td align="center" bgcolor="#0a1628"
                style="background-color: #0a1628; padding-top: 24px; padding-bottom: 24px; padding-left: 40px; padding-right: 40px;">
              <img src="https://cdn.acme.com/email/logo-white.png" width="120" height="32" alt="Acme Logo"
                   style="display: block; border: 0;">
            </td>
          </tr>

          <!-- Hero — all caps heading, excessive punctuation, fake urgency -->
          <tr>
            <td style="padding-top: 40px; padding-bottom: 16px; padding-left: 40px; padding-right: 40px; text-align: center;">
              <h1 style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif; font-size: 32px;
                         color: #0a1628; margin: 0 0 12px; mso-line-height-rule: exactly; line-height: 40px;">
                HUGE SUMMER SALE - DON'T MISS OUT!!!
              </h1>
              <!-- Vague urgency: no expiry date or specific end time given -->
              <p style="font-family: Arial, sans-serif; font-size: 16px; color: #555555;
                        line-height: 26px; margin: 0; mso-line-height-rule: exactly;">
                Limited time offer. Act now before it's too late!
              </p>
            </td>
          </tr>

          <!-- Promo image — non-descriptive alt text -->
          <tr>
            <td style="padding-left: 40px; padding-right: 40px; padding-bottom: 24px;">
              <img src="https://cdn.acme.com/email/summer-promo.jpg" width="520" height="240"
                   alt="promotional image"
                   style="display: block; border: 0; width: 100%; max-width: 520px;">
            </td>
          </tr>

          <!-- Body — no personalisation despite variable being available, passive voice,
               salutation "Dear Valued Customer" instead of first name -->
          <tr>
            <td style="padding-top: 0; padding-bottom: 24px; padding-left: 40px; padding-right: 40px;">
              <p style="font-family: Arial, sans-serif; font-size: 16px; color: #333333;
                        line-height: 26px; margin: 0 0 16px; mso-line-height-rule: exactly;">
                Dear Valued Customer,
              </p>
              <p style="font-family: Arial, sans-serif; font-size: 16px; color: #333333;
                        line-height: 26px; margin: 0 0 16px; mso-line-height-rule: exactly;">
                A sale has been prepared for you by our team. Discounts of up to 50% have been applied
                to selected products across our range. Items can be browsed and purchased via the
                link provided below. Your satisfaction is important to us.
              </p>
              <p style="font-family: Arial, sans-serif; font-size: 16px; color: #333333;
                        line-height: 26px; margin: 0 0 24px; mso-line-height-rule: exactly;">
                Please do not hesitate to take advantage of this offer at your earliest convenience.
              </p>

              <!-- Primary CTA — generic "Click Here" with no context -->
              <!--[if mso]>
              <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml"
                           xmlns:w="urn:schemas-microsoft-com:office:word"
                           href="https://acme.com/sale"
                           style="height:48px;v-text-anchor:middle;width:200px;"
                           arcsize="8%" fillcolor="#e63946" strokecolor="#e63946">
                <w:anchorlock/>
                <center style="color:#ffffff;font-family:Arial,sans-serif;font-size:16px;font-weight:bold;">
                  Click Here
                </center>
              </v:roundrect>
              <![endif]-->
              <!--[if !mso]><!-->
              <table border="0" cellpadding="0" cellspacing="0" role="presentation"
                     style="mso-table-lspace: 0pt; mso-table-rspace: 0pt;">
                <tr>
                  <td align="center" bgcolor="#e63946"
                      style="background-color: #e63946; border-radius: 6px;">
                    <a href="https://acme.com/sale"
                       target="_blank"
                       style="display: inline-block; color: #ffffff;
                              font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;
                              font-size: 16px; font-weight: bold; line-height: 48px;
                              text-decoration: none; padding-left: 28px; padding-right: 28px;
                              mso-hide: all;">
                      Click Here
                    </a>
                  </td>
                </tr>
              </table>
              <!--<![endif]-->
            </td>
          </tr>

          <!-- Second CTA block — competing primary actions, no hierarchy -->
          <tr>
            <td style="padding-top: 0; padding-bottom: 8px; padding-left: 40px; padding-right: 40px;
                       border-top: 1px solid #eeeeee;">
              <p style="font-family: Arial, sans-serif; font-size: 15px; color: #333333;
                        line-height: 24px; margin: 24px 0 8px; mso-line-height-rule: exactly;">
                Want to browse by category?
              </p>
              <!--[if mso]>
              <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml"
                           xmlns:w="urn:schemas-microsoft-com:office:word"
                           href="https://acme.com/sale/womens"
                           style="height:44px;v-text-anchor:middle;width:200px;"
                           arcsize="8%" fillcolor="#0a1628" strokecolor="#0a1628">
                <w:anchorlock/>
                <center style="color:#ffffff;font-family:Arial,sans-serif;font-size:15px;font-weight:bold;">
                  Shop Women's
                </center>
              </v:roundrect>
              <![endif]-->
              <!--[if !mso]><!-->
              <table border="0" cellpadding="0" cellspacing="0" role="presentation"
                     style="mso-table-lspace: 0pt; mso-table-rspace: 0pt; margin-bottom: 12px;">
                <tr>
                  <td align="center" bgcolor="#0a1628"
                      style="background-color: #0a1628; border-radius: 6px;">
                    <a href="https://acme.com/sale/womens"
                       target="_blank"
                       style="display: inline-block; color: #ffffff;
                              font-family: Arial, sans-serif; font-size: 15px; font-weight: bold;
                              line-height: 44px; text-decoration: none;
                              padding-left: 24px; padding-right: 24px; mso-hide: all;">
                      Shop Women's
                    </a>
                  </td>
                </tr>
              </table>
              <!--<![endif]-->
              <!-- Third CTA as a plain text link — three competing primary actions
                   with no visual hierarchy guidance for the reader -->
              <p style="font-family: Arial, sans-serif; font-size: 15px; color: #333333;
                        line-height: 24px; margin: 12px 0 24px; mso-line-height-rule: exactly;">
                Or <a href="https://acme.com/sale/mens"
                      style="color: #e63946; text-decoration: underline;">shop the men's sale</a>.
              </p>
            </td>
          </tr>

        </table>
        <!--[if mso]>
          </td></tr>
        </table>
        <![endif]-->

        <!-- Footer -->
        <!--[if mso]>
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="600">
          <tr><td>
        <![endif]-->
        <table width="600" border="0" cellpadding="0" cellspacing="0" role="presentation"
               style="mso-table-lspace: 0pt; mso-table-rspace: 0pt;">
          <tr>
            <!-- Long, legalistic unsubscribe copy — hostile tone, no brand voice -->
            <td style="padding-top: 20px; padding-bottom: 20px; padding-left: 40px; padding-right: 40px;
                       font-family: Arial, sans-serif; font-size: 12px; color: #888888; line-height: 20px;">
              <p style="margin: 0 0 6px;">
                Acme Inc. &bull; 350 Fifth Avenue, New York, NY 10118
              </p>
              <p style="margin: 0 0 6px;">
                You are receiving this email because you have previously made a purchase or created
                an account on our website. If you no longer wish to receive promotional email
                communications of this nature from Acme Inc., you may click the link below to
                remove yourself from our mailing list. Please note that transactional emails
                related to your account and orders will continue to be sent regardless.
              </p>
              <p style="margin: 0;">
                <a href="{{unsubscribe_url}}" target="_blank"
                   style="color: #888888; text-decoration: underline;">Click here to unsubscribe</a>
              </p>
            </td>
          </tr>
        </table>
        <!--[if mso]>
          </td></tr>
        </table>
        <![endif]-->

      </td>
    </tr>
  </table>

</body>
</html>
