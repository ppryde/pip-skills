<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office" lang="en">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="x-apple-disable-message-reformatting">
  <meta name="color-scheme" content="light dark">
  <meta name="supported-color-schemes" content="light dark">
  <title>{{subject}}</title>
  <!--[if mso]>
  <xml>
    <o:OfficeDocumentSettings>
      <o:PixelsPerInch>96</o:PixelsPerInch>
      <o:AllowPNG/>
    </o:OfficeDocumentSettings>
  </xml>
  <![endif]-->
  <style type="text/css">
    body { margin: 0; padding: 0; background-color: #f5f5f5; -webkit-text-size-adjust: 100%; }
    table { border-collapse: separate; }
    img { border: 0; display: block; }
    a[x-apple-data-detectors] { color: inherit !important; text-decoration: inherit !important; }
    #MessageViewBody a { color: inherit; text-decoration: none; }
    .ExternalClass { width: 100%; }
    .ExternalClass, .ExternalClass p, .ExternalClass span, .ExternalClass td { line-height: 100%; }
    @media (prefers-color-scheme: dark) {
      .email-bg { background-color: #1e1e1e !important; }
      .email-body { background-color: #2d2d2d !important; color: #e0e0e0 !important; }
    }
    @media (max-width: 600px) {
      .container { width: 100% !important; }
    }
  </style>
</head>
<body style="margin: 0; padding: 0; background-color: #f5f5f5;" class="email-bg">

  <div style="display: none; visibility: hidden; opacity: 0; font-size: 0; line-height: 0; max-height: 0; overflow: hidden;">
    {{preheader}}&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;
  </div>

  <!--[if mso]>
  <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f5f5f5;">
    <tr><td align="center">
  <![endif]-->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation"
         style="mso-table-lspace: 0pt; mso-table-rspace: 0pt; background-color: #f5f5f5;">
    <tr>
      <td align="center" style="padding-top: 32px; padding-bottom: 32px; padding-left: 16px; padding-right: 16px;">

        <!--[if mso]>
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="600">
          <tr><td>
        <![endif]-->
        <table class="container" width="600" border="0" cellpadding="16" cellspacing="0" role="presentation"
               style="mso-table-lspace: 0pt; mso-table-rspace: 0pt; background-color: #ffffff;" class="email-body">

          <!-- Header -->
          <tr>
            <td style="padding-top: 32px; padding-bottom: 16px; padding-left: 40px; padding-right: 40px; border-bottom: 1px solid #e5e5e5;">
              <img src="https://cdn.acme.com/email/logo-dark.png" width="120" height="32" alt="Acme"
                   style="display: block; border: 0;">
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding-top: 32px; padding-bottom: 24px; padding-left: 40px; padding-right: 40px;">
              <h1 style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif; font-size: 24px;
                         color: #111111; margin-top: 0; margin-bottom: 16px; mso-line-height-alt: 32px;">
                {{heading}}
              </h1>
              <p style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif; font-size: 16px;
                        color: #444444; line-height: 26px; margin: 0 0 16px; mso-line-height-rule: exactly;">
                Hi {{#if first_name}}{{first_name}}{{else}}there{{/if}},
              </p>
              <p style="font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif; font-size: 16px;
                        color: #444444; line-height: 26px; margin: 0 0 24px; mso-line-height-rule: exactly;">
                {{body_copy}}
              </p>

              <!-- CTA -->
              <!--[if mso]>
              <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml"
                           xmlns:w="urn:schemas-microsoft-com:office:word"
                           href="{{cta_url}}"
                           style="height:48px;v-text-anchor:middle;width:200px;"
                           arcsize="8%" fillcolor="#111111" strokecolor="#111111">
                <w:anchorlock/>
                <center style="color:#ffffff;font-family:Arial,sans-serif;font-size:16px;font-weight:bold;">
                  {{cta_label}}
                </center>
              </v:roundrect>
              <![endif]-->
              <!--[if !mso]><!-->
              <table border="0" cellpadding="0" cellspacing="0" role="presentation"
                     style="mso-table-lspace: 0pt; mso-table-rspace: 0pt;">
                <tr>
                  <td align="center" bgcolor="#111111"
                      style="background-color: #111111; border-radius: 6px;">
                    <a href="{{cta_url}}"
                       target="_blank"
                       style="display: inline-block; color: #ffffff;
                              font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;
                              font-size: 16px; font-weight: bold; line-height: 48px;
                              text-decoration: none; padding-left: 28px; padding-right: 28px;
                              mso-hide: all;">
                      {{cta_label}}
                    </a>
                  </td>
                </tr>
              </table>
              <!--<![endif]-->
            </td>
          </tr>

          <!-- Data summary table -->
          <tr>
            <td style="padding-top: 0; padding-bottom: 32px; padding-left: 40px; padding-right: 40px;">
              <table width="100%" border="0" cellpadding="0" cellspacing="0"
                     style="mso-table-lspace: 0pt; mso-table-rspace: 0pt; border-top: 1px solid #e5e5e5;">
                <tr>
                  <th align="left" style="padding-top: 16px; padding-bottom: 8px;
                                          font-family: Arial, sans-serif; font-size: 11px;
                                          color: #888888; text-transform: uppercase;
                                          letter-spacing: 1px; font-weight: normal;">
                    Detail
                  </th>
                  <th align="right" style="padding-top: 16px; padding-bottom: 8px;
                                           font-family: Arial, sans-serif; font-size: 11px;
                                           color: #888888; text-transform: uppercase;
                                           letter-spacing: 1px; font-weight: normal;">
                    Value
                  </th>
                </tr>
                {{#each line_items}}
                <tr>
                  <td style="padding-bottom: 10px; font-family: Arial, sans-serif; font-size: 15px; color: #333333;">
                    {{label}}
                  </td>
                  <td align="right" style="padding-bottom: 10px; font-family: Arial, sans-serif; font-size: 15px; color: #333333;">
                    {{value}}
                  </td>
                </tr>
                {{/each}}
              </table>
            </td>
          </tr>

        </table>
        <!--[if mso]>
          </td></tr>
        </table>
        <![endif]-->

        <!-- Footer -->
        <!--[if mso]>
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="600">
          <tr><td>
        <![endif]-->
        <table class="container" width="600" border="0" cellpadding="0" cellspacing="0" role="presentation"
               style="mso-table-lspace: 0pt; mso-table-rspace: 0pt;">
          <tr>
            <td style="padding-top: 20px; padding-bottom: 20px; padding-left: 40px; padding-right: 40px;
                       font-family: Arial, sans-serif; font-size: 12px; color: #888888; line-height: 20px;">
              <p style="margin: 0 0 6px;">
                Acme Inc. &bull; 350 Fifth Avenue, New York, NY 10118
              </p>
              <p style="margin: 0;">
                <a href="{{unsubscribe_url}}" target="_blank"
                   style="color: #888888; text-decoration: underline;">Unsubscribe</a>
                &nbsp;&bull;&nbsp;
                <a href="{{preferences_url}}" target="_blank"
                   style="color: #888888; text-decoration: underline;">Email preferences</a>
                &nbsp;&bull;&nbsp;
                <a href="https://acme.com/privacy" target="_blank"
                   style="color: #888888; text-decoration: underline;">Privacy policy</a>
              </p>
            </td>
          </tr>
        </table>
        <!--[if mso]>
          </td></tr>
        </table>
        <![endif]-->

      </td>
    </tr>
  </table>
  <!--[if mso]>
    </td></tr>
  </table>
  <![endif]-->

</body>
</html>
