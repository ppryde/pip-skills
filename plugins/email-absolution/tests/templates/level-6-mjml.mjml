<mjml>
  <mj-head>
    <mj-title>{{subject}}</mj-title>
    <!-- No <mj-preview> — MJML's native preheader mechanism is absent -->

    <mj-font name="Lato" href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700" />

    <mj-attributes>
      <!-- mj-all sets font-family to web font for every component — compiled output
           uses font-family: 'Lato', Arial in every <td>; Outlook and Gmail
           ignore the web font entirely, and there is no guaranteed fallback path -->
      <mj-all font-family="'Lato', Arial, sans-serif" />

      <mj-text font-size="16px" line-height="26px" color="#333333" padding="0" />
      <mj-section padding="0" />
    </mj-attributes>
  </mj-head>

  <mj-body background-color="#f4f4f4">

    <!-- Hero section -->
    <!-- background-url + background-size: mj-section compiles background-url to a
         VML conditional for Outlook, but background-size is passed as inline CSS
         which Outlook ignores — hero will not scale or crop in Outlook -->
    <mj-section background-color="#1a2e4a"
                 background-url="https://cdn.acme.com/email/hero.jpg"
                 background-size="cover"
                 background-position="center"
                 padding="48px 40px">
      <!-- mj-section has padding="0" from mj-attributes default,
           and this section sets padding="48px 40px" — but mj-column below also
           inherits the default padding="0". When both section and column padding
           are set, MJML stacks them, creating unexpected double-padding in
           compiled output in some MJML versions (inner cells get padding applied
           twice) -->
      <mj-column padding="24px 0">
        <!-- mj-image without fluid-on-mobile: MJML images default to fixed width
             in the compiled output; without fluid-on-mobile="true" the logo will
             not scale down on narrow mobile viewports -->
        <mj-image src="https://cdn.acme.com/email/logo-white.png"
                  width="140px"
                  alt="Acme"
                  align="left" />
        <mj-text color="#ffffff" font-size="28px" font-weight="bold" padding-top="16px">
          {{heading}}
        </mj-text>
        <mj-text color="#ffffff" font-size="16px" padding-top="8px">
          {{subheading}}
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Body section -->
    <mj-section background-color="#ffffff" padding="32px 40px">
      <mj-column>
        <mj-text padding-bottom="16px">
          Hi {{first_name}},
        </mj-text>
        <mj-text padding-bottom="24px">
          {{body_copy}}
        </mj-text>

        <!-- mj-button compiles to a <table> + <td> + <a> pattern.
             MJML does NOT emit a VML <v:roundrect> fallback.
             In Outlook 2007–2019 the button renders as a plain underlined anchor
             link with no background-color or border-radius. -->
        <mj-button background-color="#1a2e4a"
                   color="#ffffff"
                   font-size="16px"
                   font-weight="bold"
                   border-radius="6px"
                   href="{{cta_url}}"
                   padding="14px 28px">
          {{cta_label}}
        </mj-button>

        <!-- mj-raw injects markup directly into the compiled output, bypassing
             MJML's sanitisation and table structure. Any HTML errors or missing
             attributes in the raw block are invisible at compile time. -->
        <mj-raw>
          <div style="margin-top: 24px; font-size: 13px; color: #888888;">
            {{#if promo_note}}<p style="margin: 0;">{{promo_note}}</p>{{/if}}
          </div>
        </mj-raw>
      </mj-column>
    </mj-section>

    <!-- Two-column section -->
    <mj-section background-color="#f8fafc" padding="24px 40px">
      <mj-column>
        <mj-text font-size="13px" font-weight="bold" color="#64748b" padding-bottom="8px">
          Feature One
        </mj-text>
        <mj-text>{{feature_one_copy}}</mj-text>
      </mj-column>
      <mj-column>
        <mj-text font-size="13px" font-weight="bold" color="#64748b" padding-bottom="8px">
          Feature Two
        </mj-text>
        <mj-text>{{feature_two_copy}}</mj-text>
      </mj-column>
    </mj-section>

    <!-- Footer -->
    <!-- Footer links use css-class styling only. MJML compiles css-class rules
         into a <style> block in the <head>, not as inline styles. Gmail strips
         the <style> block entirely, so footer link colours and decoration
         will be overridden by Gmail's default link styling. -->
    <mj-section background-color="#ffffff" padding="20px 40px">
      <mj-column css-class="footer">
        <mj-text font-size="12px" color="#888888" padding-bottom="6px">
          Acme Inc. &bull; 350 Fifth Avenue, New York, NY 10118
        </mj-text>
        <mj-text font-size="12px" color="#888888">
          <a href="{{unsubscribe_url}}" style="color: #888888; text-decoration: underline;">Unsubscribe</a>
          &bull;
          <a href="{{preferences_url}}" style="color: #888888; text-decoration: underline;">Email preferences</a>
          &bull;
          <a href="https://acme.com/privacy" style="color: #888888; text-decoration: underline;">Privacy policy</a>
        </mj-text>
      </mj-column>
    </mj-section>

  </mj-body>
</mjml>
